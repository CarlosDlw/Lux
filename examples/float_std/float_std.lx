namespace FloatStd;

use std::log::println;

int32 main() {
    float32 a = 3.14;
    float32 b = 2.718;
    float64 c = 3.141592653589793;
    float64 d = 1.0e10;
    double  e = 2.718281828459045;
    double  f = 0.001;

    println(a);
    println(b);
    println(c);
    println(d);
    println(e);
    println(f);

    ret 0;
}
