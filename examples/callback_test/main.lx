namespace CallbackTest;

#include <stdlib.h>
#include <stdio.h>
#include <string.h>

int32 compareInts(*void a, *void b) {
    *int32 ia = a as *int32;
    *int32 ib = b as *int32;
    ret *ia - *ib;
}

void onExit() {
    printf(c"[PASS] atexit callback works\n");
    printf(c"=== Done ===\n");
}

int32 main() {
    printf(c"=== Callback Test ===\n");

    // Test 1: atexit callback
    atexit(onExit);

    // Test 2: qsort callback
    *void buf = malloc(20 as usize);
    defer free(buf);

    *int32 arr = buf as *int32;
    *arr = 5;
    *(arr + 1) = 3;
    *(arr + 2) = 8;
    *(arr + 3) = 1;
    *(arr + 4) = 4;

    printf(c"before: %d %d %d %d %d\n", *arr, *(arr+1), *(arr+2), *(arr+3), *(arr+4));
    qsort(buf, 5 as usize, 4 as usize, compareInts);
    printf(c"after:  %d %d %d %d %d\n", *arr, *(arr+1), *(arr+2), *(arr+3), *(arr+4));

    int32 ok = 1;
    if (*arr != 1) { ok = 0; }
    if (*(arr+1) != 3) { ok = 0; }
    if (*(arr+2) != 4) { ok = 0; }
    if (*(arr+3) != 5) { ok = 0; }
    if (*(arr+4) != 8) { ok = 0; }

    if (ok == 1) {
        printf(c"[PASS] qsort callback works\n");
    } else {
        printf(c"[FAIL] qsort result incorrect\n");
    }

    // Test 3: bsearch callback
    *void buf2 = malloc(20 as usize);
    defer free(buf2);
    *int32 sorted = buf2 as *int32;
    *sorted = 10;
    *(sorted + 1) = 20;
    *(sorted + 2) = 30;
    *(sorted + 3) = 40;
    *(sorted + 4) = 50;

    int32 key = 30;
    *void found = bsearch(&key as *void, buf2, 5 as usize, 4 as usize, compareInts);
    if (found != null) {
        *int32 result = found as *int32;
        printf(c"bsearch found: %d [PASS]\n", *result);
    } else {
        printf(c"[FAIL] bsearch not found\n");
    }

    ret 0;
}
