{
  "name": "tollvm",
  "displayName": "ToLLVM Language",
  "description": "Syntax highlighting for the ToLLVM language (.tm files)",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "tollvm",
        "aliases": ["ToLLVM", "tollvm"],
        "extensions": [".tm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tollvm",
        "scopeName": "source.tollvm",
        "path": "./syntaxes/tollvm.tmLanguage.json"
      }
    ]
  }
}
