namespace Main;

use std::log::println;
use std::test::{ assertEqual };

void fillVec<T>(T value, int32 size, *vec<T> v) {
  for int32 i in size {
    v.push(value);
  }
}

void assignVec<T>(T value, int32 size, *vec<T> v) {
  for int32 i in size {
    v[i] = value;
  }
}

int32 testVecPointers() {
    println("[Testing vec pointers...]");

    vec<int32> a;
    fillVec<int32>(42, 5, &a);
    assertEqual(a.len(), 5);
    assertEqual(a.at(0), 42);
    assertEqual(a.at(4), 42);

    vec<int32> b;
    b.push(10);
    b.push(20);
    b.push(30);
    assignVec<int32>(99, 3, &b);
    assertEqual(b.len(), 3);
    assertEqual(b.at(0), 99);
    assertEqual(b.at(1), 99);
    assertEqual(b.at(2), 99);

    println("✔ vec pointer tests passed");
    ret 0;
}
