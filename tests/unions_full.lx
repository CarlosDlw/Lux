namespace Main;

use std::log::println;
use std::test::{ assertEqual };

union UIntOrFloat {
    int32 i;
    float32 f;
}

union UResult<T, E> {
    T ok;
    E err;
}

int32 testUnionsFull() {
    println("[Testing unions: literals/mutation/shared-memory/generic unions...]");

    UIntOrFloat u = UIntOrFloat { i: 42 };
    assertEqual(u.i, 42);

    u.f = 3.14 as float32;
    float64 uv = u.f as float64;
    assertEqual(uv > 3.13 && uv < 3.15, true);

    int32 raw = u.i;
    assertEqual(raw != 42, true);

    UResult<int32, string> ok = UResult<int32, string> { ok: 42 };
    UResult<int32, string> err = UResult<int32, string> { err: "boom" };

    assertEqual(ok.ok, 42);
    assertEqual(err.err, "boom");

    ok.err = "changed";
    assertEqual(ok.err, "changed");

    println("✔ unions tests passed");
    ret 0;
}
