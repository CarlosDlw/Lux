namespace Main;

use std::log::println;
use std::test::{ assertEqual };

tuple<int32, int32> tupleSwap(tuple<int32, int32> t) {
    ret (t.1, t.0);
}

tuple<string, int32, bool> tupleMakeRecord(string name, int32 age) {
    ret (name, age, age >= 18);
}

int32 testTuplesFull() {
    println("[Testing tuples: declarations/literals/access/destructuring...]");

    tuple<int32, string> pair = (42, "hello");
    tuple<int32, float64, bool> triple = (10, 3.14, true);
    assertEqual(pair.0, 42);
    assertEqual(pair.1, "hello");
    assertEqual(triple.0, 10);
    assertEqual(triple.1, 3.14);
    assertEqual(triple.2, true);

    auto inferredPair = (7, "lux");
    auto inferredTriple = (11, 2.5, false);
    assertEqual(inferredPair.0, 7);
    assertEqual(inferredPair.1, "lux");
    assertEqual(inferredTriple.0, 11);
    assertEqual(inferredTriple.1, 2.5);
    assertEqual(inferredTriple.2, false);

    tuple<int32, tuple<string, bool>> nested = (99, ("inner", true));
    assertEqual(nested.0, 99);
    assertEqual(nested.1.0, "inner");
    assertEqual(nested.1.1, true);

    auto (x, y) = (100, 200);
    assertEqual(x, 100);
    assertEqual(y, 200);

    auto (name, age, adult) = tupleMakeRecord("alice", 25);
    assertEqual(name, "alice");
    assertEqual(age, 25);
    assertEqual(adult, true);

    auto swapped = tupleSwap((3, 7));
    assertEqual(swapped.0, 7);
    assertEqual(swapped.1, 3);

    auto ptrBase = (10, 20);
    *tuple<int32, int32> ptr = &ptrBase;
    assertEqual(ptr->0, 10);
    assertEqual(ptr->1, 20);

    auto ptrNestedValue = (1, (2, 3));
    *tuple<int32, tuple<int32, int32>> ptrNested = &ptrNestedValue;
    assertEqual(ptrNested->0, 1);
    assertEqual(ptrNested->1.0, 2);
    assertEqual(ptrNested->1.1, 3);

    int32 a = 5;
    int32 b = 10;
    auto computed = (a + b, a * b);
    assertEqual(computed.0, 15);
    assertEqual(computed.1, 50);

    auto big = (1, 2, 3, 4, 5);
    assertEqual(big.0, 1);
    assertEqual(big.4, 5);

    println("[OK] tuples tests passed");
    ret 0;
}