namespace Main;

use std::log::println;
use std::test::{ assertEqual };

type BinOp = fn(int32, int32) -> int32;

int32 aliasAdd(int32 a, int32 b) {
    ret a + b;
}

int32 aliasMul(int32 a, int32 b) {
    ret a * b;
}

int32 aliasApply(BinOp op, int32 x, int32 y) {
    ret op(x, y);
}

int32 testTypeAliasesFull() {
    println("[Testing type aliases: fn aliases/cstring interchangeability...]");

    BinOp op = aliasAdd;
    assertEqual(op(3, 4), 7);

    assertEqual(aliasApply(aliasMul, 5, 6), 30);

    op = aliasMul;
    assertEqual(op(3, 4), 12);

    cstring greeting = c"Hello!";
    *char asCharPtr = greeting;
    cstring asCStringAgain = asCharPtr as cstring;

    assertEqual(fromCStr(asCStringAgain), "Hello!");
    assertEqual(sizeof(cstring), sizeof(*char));
    assertEqual(typeof(asCharPtr), "*char");

    println("✔ type aliases tests passed");
    ret 0;
}
